# Large raw data files — provide via data/raw/SOURCES.md instructions
data/raw/*.parquet
data/raw/*.csv
data/raw/postseason/

# Processed outputs — regenerated by pipeline scripts
data/processed/

# Analysis outputs — large generated files (notebooks and PDFs are committed; heavy CSVs/HTMLs are not)
analysis/**/*.csv
analysis/**/*.parquet
analysis/**/*.html
# To commit a specific analysis output, use: git add -f analysis/player_archetypes/my_file.csv

# Python
__pycache__/
*.py[cod]
*.pyo
.env
venv/
.venv/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.code-workspace
